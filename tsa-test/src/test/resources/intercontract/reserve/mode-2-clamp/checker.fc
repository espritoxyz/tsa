#include "../../../imports/stdlib.fc";
#include "../../../imports/tsa_functions.fc";

() on_internal_message_send(int balance, int msg_value, cell in_msg_full, slice msg_body, int to_reserve) impure method_id {
    tsa_forbid_failures();
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    tsa_assert_not(flags & 1);
    tsa_assert(msg_value <= 1000000000); ;; 1 ton
    tsa_allow_failures();
}

() main() impure {
    tsa_forbid_failures();
    var data = get_data().begin_parse();
    int initial_balance = data~load_uint(64);
    int to_reserve = data~load_int(64);

    int sender_balance = tsa_get_balance(1);
    tsa_assert(sender_balance == initial_balance);
    tsa_allow_failures();

    tsa_send_internal_message_with_body(
        begin_cell()
            .store_uint(to_reserve, 64)
            .end_cell()
            .begin_parse(),
        1,
        0
    );
    throw(10000); ;; success
}
