#include "../imports/stdlib.fc";

int due_payment() asm "DUEPAYMENT";

;;; Branches on the symbolic value of c7[15] DUEPAYMENT. We expect the
;;; symbolic engine to explore both branches because the initial value of
;;; this parameter is bounded by [0, 0.1 TON).
() recv_internal(int msg_value, cell in_msg_full, slice in_msg) impure {
    int due = due_payment();

    if (due == 0) {
        throw(201);
    }

    if (due >= 50000000) { ;; 0.05 TON
        throw(202);
    }

    throw(203);
}
