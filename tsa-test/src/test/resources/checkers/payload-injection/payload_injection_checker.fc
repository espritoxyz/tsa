#include "../../imports/stdlib.fc";
#include "../../imports/tsa_functions.fc";

const int DEADBEEF = 0xdeadbeef;
const int VULNERABILITY_FOUND = 1000;
const int VULNERABILITY_NOT_FOUND = 500;

global int found_injection;

() on_internal_message_send(int balance, int msg_value, cell in_msg_full, slice msg_body, int input_id) impure method_id {
    var opcode = msg_body.preload_uint(32);
    tsa_assert(opcode == 0x698cba08); ;; temporary workaround for a good initial message
}


() on_out_message(cell msg_full, slice msg_body, int receiver_contract_id, int sender_contract_id) impure method_id {
    if (sender_contract_id != 1) {
        return ();
    }
    if (receiver_contract_id != -1) {
        return ();
    }

    int op = msg_body~load_uint(32);
    if (op == DEADBEEF) {
        found_injection = 1;
    }
}

() main() impure {
    found_injection = 0;

    tsa_forbid_failures();
    tsa_send_internal_message(1, 0);
    tsa_allow_failures();

    throw_if(VULNERABILITY_FOUND, found_injection == 1);
    throw(VULNERABILITY_NOT_FOUND);
}
