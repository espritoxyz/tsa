#include "../../imports/stdlib.fc";
#include "../../imports/tsa_functions.fc";


() on_internal_message_send(int balance, int msg_value, cell in_msg_full, slice msg_body, int input_id) impure method_id {
    var msg = in_msg_full.begin_parse();
    msg~load_uint(4);
    var sender = msg~load_msg_addr();
    tsa_fetch_enumerate_model_values(sender, 1001);
}

() main() impure {
    (var code, var data) = tsa_enable_sender_address_as_hash();
    tsa_fetch_enumerate_model_values(code.begin_parse(), 1000);
    tsa_send_internal_message(1, 0);
    throw(1000);
}
