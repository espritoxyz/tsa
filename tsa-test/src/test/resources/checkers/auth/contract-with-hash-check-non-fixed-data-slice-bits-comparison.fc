#include "util.fc";
#include "../../imports/stdlib.fc";

const int workchain = 0;
slice calc_address(cell state_init) inline {
    return begin_cell().store_uint(4, 3) ;; 0x100 : $10 + anycast (Maybe = 0)
        .store_int(workchain, 8)
        .store_uint(
            cell_hash(state_init), 256)
        .end_cell()
        .begin_parse();
}

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice msg_body) impure {
    var msg_cell = in_msg_full.begin_parse();
    msg_cell~load_uint(4); ;; flags
    var sender_address = msg_cell~load_msg_addr();

    var expected_code = begin_cell().store_uint(15, 8).end_cell();
    var expected_nonce = msg_body~load_uint(64);
    var expected_data = begin_cell().store_uint(expected_nonce, 64).end_cell();
    var expected_sender_stateinit = form_stateinit(expected_code, expected_data);
    var expected_sender_address = calc_address(expected_sender_stateinit);
    throw_if(500, ~ equal_slice_bits(expected_sender_address, sender_address));
}
