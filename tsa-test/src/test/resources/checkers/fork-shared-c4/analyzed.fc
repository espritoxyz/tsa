#include "../../imports/stdlib.fc";

() recv_internal(int balance, int msg_value, cell in_msg_full, slice msg_body) impure {
    slice cs = in_msg_full.begin_parse();
    cs~load_uint(4); ;; flags
    slice sender = cs~load_msg_addr();

    int op = msg_body~load_uint(32);

    slice ds = get_data().begin_parse();
    slice owner = ds~load_msg_addr();
    int counter = ds~load_uint(64);
    int seqno = ds~load_uint(32);
    if (op == 0x1002) {
        throw_unless(401, equal_slice_bits(sender, owner));
    } else {
        throw(200);
    }
    set_data(begin_cell().store_slice(owner).store_uint(counter, 64).store_uint(seqno, 32).end_cell()); ;; this set_data creates a wrong register in a separate state
}
