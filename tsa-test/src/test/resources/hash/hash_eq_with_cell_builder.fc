#include "util.fc";
#include "../imports/stdlib.fc";



() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    var d1 = begin_cell().store_uint(15, 32);
    var d2 = in_msg.preload_ref();
    int hash1 = d1.builder_hash();
    int hash2 = d2.cell_hash();
    if (hash1 == hash2) {
        throw(111);
    } else {
        throw(112);
    }
    return ();
}
