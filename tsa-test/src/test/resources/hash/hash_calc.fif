"Fift.fif" include
"Asm.fif" include

PROGRAM{
  0 DECLMETHOD simple_cell_hash
  1 DECLMETHOD simple_slice_hash
  2 DECLMETHOD slice_ops_hash
  3 DECLMETHOD ref_hash
  4 DECLMETHOD dict_hash_1
  5 DECLMETHOD dict_hash_2
  6 DECLMETHOD simple_hashbu
  7 DECLMETHOD ref_hashbu
  8 DECLMETHOD sha256_0
  9 DECLMETHOD sha256_with_ref
  10 DECLMETHOD hashext_sha256_1

  simple_cell_hash PROC:<{
      NEWC
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      STSLICER
      ENDC
      HASHCU
  }>
  simple_slice_hash PROC:<{
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      HASHSU
  }>
  slice_ops_hash PROC:<{
      x{646676686a7364667662736a64616261}  PUSHSLICE  // just some slice
      2 LDI
      HASHSU
  }>
  ref_hash PROC:<{
      NEWC
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      STSLICER
      ENDC
      NEWC
      STREF
      ENDC
      HASHCU
    }>
  dict_hash_1 PROC:<{
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      x{6766864616261} PUSHSLICE  // just some slice
      NULL
      10 PUSHINT
      DICTSET
      HASHCU
  }>
  dict_hash_2 PROC:<{
      x{} PUSHSLICE
      x{4000000000000000} PUSHSLICE
      x{} PUSHSLICE
      x{0000000000000000} PUSHSLICE
      NULL
      64 PUSHINT
      DICTSET
      64 PUSHINT
      DICTSET
      HASHCU
  }>
  simple_hashbu PROC:<{
      NEWC
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      STSLICER
      HASHBU
  }>
  ref_hashbu PROC:<{
      NEWC
      x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
      STSLICER
      ENDC
      NEWC
      STREF
      HASHBU
    }>
  sha256_0 PROC:<{
    x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
    SHA256U
  }>

  sha256_with_ref PROC:<{
    x{646676686a7364667662736a64616261} PUSHSLICE
    NEWC
    STSLICE
    ENDC // some ref

    13 PUSHINT
    NEWC
    4 STI
    STREF

    SHA256U
  }>

  hashext_sha256_1 PROC:<{
        x{646676686a7364667662736a64616261} PUSHSLICE  // just some slice
        1 PUSHINT
        HASHEXT_SHA256
    }>
}END>c
