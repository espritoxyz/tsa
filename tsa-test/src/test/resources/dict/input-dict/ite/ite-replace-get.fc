#include "../../../imports/stdlib.fc";
#include "../util.fc";

() test(slice in_msg, int index) impure method_id (1) {

    cell dict_1 = new_dict()
        .udict_set(64, 7, wrap_in_cell(100));
    cell dict_2 = new_dict()
        .udict_set(64, 7, wrap_in_cell(200));
    cell ite_dict = my_mk_ite(dict_1, dict_2, index);

    (cell replaced_dict, slice old_value, int ok) = udict_replace_get(ite_dict, 64, 7, wrap_in_cell(999));
    throw_unless(400, ok);

    (slice new_value, int found) = replaced_dict.udict_get?(64, 7);
    throw_unless(401, found);
    throw_unless(402, new_value.unwrap() == 999);

    int old = old_value.unwrap();
    throw_if(500, old == 100);
    throw_if(501, old == 200);
    throw(400);
}


() main(slice in_msg) {
    int index = in_msg~load_int(64);
    test(in_msg, index);
    return ();
}
