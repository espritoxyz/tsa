#include "../../../imports/stdlib.fc";
#include "../util.fc";

() test(slice in_msg, int index) impure method_id (1) {

    cell dict_1 = new_dict()
        .udict_set(64, 3, wrap_in_cell(100))
        .udict_set(64, 8, wrap_in_cell(100));
    cell dict_2 = new_dict()
        .udict_set(64, 6, wrap_in_cell(200))
        .udict_set(64, 8, wrap_in_cell(200));
    cell ite_dict = my_mk_ite(dict_1, dict_2, index);

    (cell rem_dict, int min_key, _, int found) = ite_dict.udict_delete_get_min(64);
    throw_unless(400, found);

    (int new_min, _, int found_after) = rem_dict.udict_get_min?(64);
    throw_unless(401, found_after);
    throw_unless(402, new_min == 8);

    throw_if(500, min_key == 3);
    throw_if(501, min_key == 6);
    throw(400);
}


() main(slice in_msg) {
    int index = in_msg~load_int(64);
    test(in_msg, index);
    return ();
}
