#include "../../../imports/stdlib.fc";
#include "../util.fc";

() test(slice in_msg, int index) impure method_id (1) {

    cell dict_1 = new_dict()
        .udict_set(64, 10, wrap_in_cell(100))
        .udict_set(64, 20, wrap_in_cell(100));
    cell dict_2 = in_msg~load_dict();

    (int next_key_2, _, int found_2) = dict_2.udict_get_next?(64, 10);
    throw_unless(300, next_key_2 == 30);

    cell ite_dict = my_mk_ite(dict_1, dict_2, index);

    (int next_key, _, int found) = ite_dict.udict_get_next?(64, 10);
    throw_unless(300, found);

    throw_if(500, next_key == 20);
    throw_if(501, next_key == 30);
    throw(400);
}


() main(slice in_msg) {
    int index = in_msg~load_int(64);
    test(in_msg, index);
    return ();
}
