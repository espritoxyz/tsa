#include "../../../imports/stdlib.fc";
#include "../util.fc";

() test(slice in_msg, int index) impure method_id (1) {

    cell dict_1 = in_msg~load_dict();
    cell dict_2 = in_msg~load_dict();

    (int max_key_1, _, int found_1) = dict_1.udict_get_max?(64);
    throw_unless(301, max_key_1 == 5);

    (int max_key_2, _, int found_2) = dict_2.udict_get_max?(64);
    throw_unless(300, max_key_2 == 9);

    cell ite_dict = my_mk_ite(dict_1, dict_2, index);

    (int max_key, _, int found) = ite_dict.udict_get_max?(64);
    throw_unless(400, found);

    throw_if(500, max_key == 5);
    throw_if(501, max_key == 9);
    throw(400);
}


() main(slice in_msg) {
    int index = in_msg~load_int(64);
    test(in_msg, index);
    return ();
}
