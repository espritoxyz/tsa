#include "../../../imports/stdlib.fc";
#include "../util.fc";

() test(slice in_msg, int index) impure method_id (1) {

    cell dict_1 = new_dict()
        .udict_set(64, 0, wrap_in_cell(100))
        .udict_set(64, 1, wrap_in_cell(100));

    cell dict_2 = in_msg~load_dict();
    dict_2 = dict_2
        .udict_set(64, 0, wrap_in_cell(200))
        .udict_set(64, 1, wrap_in_cell(200));
    cell ite_dict = my_mk_ite(dict_1, dict_2, index);

    cell ite_dict_prime = ite_dict.udict_set(64, 2, wrap_in_cell(0));
    (slice at_0, var found_at_0) = ite_dict_prime.udict_get?(64, 0);
    (slice at_1, var found_at_1) = ite_dict_prime.udict_get?(64, 1);
    (slice at_2, var found_at_2) = ite_dict_prime.udict_get?(64, 2);

    throw_unless(400, found_at_0);
    throw_unless(401, found_at_1);
    throw_unless(402, found_at_2);
    var result = at_0.unwrap() + at_1.unwrap() + at_2.unwrap();
    throw_if(500, result == 200);
    throw_if(501, result == 400);
    throw(400);
}


() main(slice in_msg) {
    int index = in_msg~load_int(64);
    test(in_msg, index);
    return ();
}
