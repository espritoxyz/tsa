#include "../imports/stdlib.fc";

(cell) mk_ite(cell d1, cell d2, int index) impure {
    cell ite_dict = new_dict()
        .udict_set(64, 0, begin_cell().store_dict(d1).end_cell().begin_parse())
        .udict_set(64, 1, begin_cell().store_dict(d2).end_cell().begin_parse());
    (slice result, int found) = udict_get?(ite_dict, 64, index);
    throw_unless(300, found);
    return result.preload_dict();
}

() main(slice in_msg) {
    int index = in_msg~load_int(64);
    cell d1 = in_msg~load_dict();
    cell d2 = in_msg~load_dict();

    (int i1, _, int f1) = d1.idict_get_next?(64, -1);
    throw_unless(301, f1);
    (int i2, _, int f2) = d2.idict_get_next?(64, -1);
    throw_unless(302, f2);

    throw_unless(303, (index == 0) | (index == 1));

    cell chosen = mk_ite(d1, d2, index);

    cell parent = begin_cell().store_dict(chosen).end_cell(); ;; so that the hash is bound to the full `chosen` ite, not to its leaves

    int expected_hash = in_msg~load_uint(256);

    throw_if(1000, parent.cell_hash() == expected_hash); ;; here we fixate the ite value

    throw(1001);
}
